# Copy this file to .env.local and fill in the values.
#
#   cp .env.example .env.local
#
# .env.local is gitignored and must never be committed. This file (.env.example)
# is committed and must never contain real values — it documents the shape only.
#
# Do not paste secrets into chat, a PR, or an issue. Put them straight into
# .env.local, and into the Vercel dashboard for production.

# ── Anthropic ────────────────────────────────────────────────────────────────
# From https://console.anthropic.com → API Keys → Create Key.
# Server-side only. NEVER prefix this NEXT_PUBLIC_ — that would ship the key
# in the browser bundle (CLAUDE.md §4.1, flagged as a live flaw in an earlier
# prototype). It is read only inside /api/* route handlers.
ANTHROPIC_API_KEY=sk-ant-...

# ── Upstash Redis ────────────────────────────────────────────────────────────
# From https://console.upstash.com → your database → "REST API" section.
# Holds conversation state, manuals, share tokens and rate-limit counters.
# Use the REST credentials, not the redis:// connection string — the REST API
# is what works on Vercel's serverless runtime.
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── PostHog (Phase 3 — not needed yet) ───────────────────────────────────────
# The share-rate funnel (CLAUDE.md §9). Safe to leave blank until Phase 3.
# The key is intentionally public — PostHog's browser SDK requires it client-side.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
